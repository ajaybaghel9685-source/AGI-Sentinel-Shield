{
  "manifest_version": 3,
  "name": "AGI-SENTINEL-ULTRA",
  "version": "1.0",
  "description": "Advanced AI Security Shield",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
