{
  "manifest_version": 3,
  "name": "AGI Sentinel Ultra (Divine Armor)",
  "version": "1.1",
  "description": "Divine protection with animated armor, trident, and helmet on all sites.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/guard.png"
  },
  "icons": {
    "16": "icons/guard.png",
    "48": "icons/guard.png",
    "128": "icons/guard.png"
  }
}
